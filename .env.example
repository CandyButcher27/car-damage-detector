# UpSure data-ingestion API — environment template.
# Copy to `.env` for local docker-compose, or use as a basis for a k8s ConfigMap/Secret.

# --- Service identity ---
UPSURE_SERVICE_NAME=data-ingestion
UPSURE_SERVICE_VERSION=1.1.0
UPSURE_ENV=production

# --- HTTP ---
# Comma-separated list. Use a real allowlist in prod, e.g.
#   UPSURE_CORS_ORIGINS=https://digi-motor.upsure.io,https://app.upsure.io
UPSURE_CORS_ORIGINS=*
UPSURE_CORS_ALLOW_CREDENTIALS=false
UPSURE_MAX_UPLOAD_BYTES=26214400        # 25 MiB
UPSURE_REQUEST_TIMEOUT_SECONDS=120

# --- Logging ---
UPSURE_LOG_LEVEL=INFO
UPSURE_LOG_JSON=true
UPSURE_LOG_INCLUDE_PATHS=false

# --- Metrics ---
UPSURE_METRICS_ENABLED=true
UPSURE_METRICS_PATH=/metrics

# --- Models ---
UPSURE_PRELOAD_MODELS=true               # load all models on startup
UPSURE_REQUIRE_MODELS_FOR_READY=true     # /readyz fails until models load

# ONNX-first paths. Set UPSURE_*_MODEL to override the auto-detection. The
# loaders search a fixed candidate list under models/ and pick the first
# that exists.
UPSURE_DAMAGE_MODEL=/app/models/damage_model.onnx
UPSURE_YOLO_MODEL=/app/models/damage_detector_v3.onnx
UPSURE_CAR_MODEL=/app/models/best_car_model_v2.onnx

# Car classifier decision threshold. Bump to >0.65 to suppress borderline
# false positives; lower it to favour recall.
UPSURE_CAR_THRESHOLD=0.65

# Binary damage head sigmoid threshold. Default raised 0.25 -> 0.50 in
# 1.1.1 after FP rate was too high on clean cars. Lower to favour
# recall; raise to favour precision.
UPSURE_DAMAGE_THRESHOLD=0.50

# YOLO box-confidence floor for the damage-type detector. Lowered 0.50 -> 0.25
# for the v3 detector (YOLO11m), whose confidence distribution sits well below
# v2 — at 0.50 it surfaced no boxes on damaged views. Re-tune via the threshold
# sweep against a labelled set.
UPSURE_YOLO_CONF=0.25
# YOLO NMS IoU threshold. Default unchanged; tune only if duplicate
# detections become an issue.
UPSURE_YOLO_IOU=0.45

# If the car ONNX flips its output convention (high output = car instead of
# non-car), set this to true.
UPSURE_CAR_MODEL_POSITIVE_HIGH=false

# Inside the container the OCR helper lives in the main interpreter.
UPSURE_OCR_PYTHON=/usr/local/bin/python

# Optional: pull model artefacts from GCS at pod startup. Empty = skip.
# UPSURE_MODELS_GCS_URI=gs://upsure-ai-models/data-ingestion/v1.1.0

# --- OCR subprocess ---
UPSURE_OCR_SUBPROCESS_TIMEOUT_SECONDS=90

# --- Plate-recognizer sidecar (Option B, separate container :9000) ---
# Called from /predict/damage for car-positive views, concurrently with the
# damage batch. Failure degrades gracefully (per_view.plate = null).
# Set UPSURE_PLATE_DETECT=false to disable (e.g. if the 256MB model strains the
# memory budget on a shared node).
UPSURE_PLATE_DETECT=true
# In docker-compose use the service name; standalone/local use http://localhost:9000
UPSURE_PLATE_SERVICE_URL=http://plate-recognizer:9000
UPSURE_PLATE_TIMEOUT_SECONDS=15
# Views to run plate detection on (plates live on front/back, not left/right).
UPSURE_PLATE_VIEWS=front,back
# Default Oman-specific plate OCR cropping when the request omits is_oman_plate.
UPSURE_PLATE_IS_OMAN=false
# Consumed by the plate-recognizer sidecar (shares this same .env via compose).
ANPR_MODEL_PATH=/app/models/digiLifeDoc_yolov4_plate_detector.onnx
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# --- Resilience ---
UPSURE_CB_FAILURE_THRESHOLD=5
UPSURE_CB_RECOVERY_SECONDS=30
UPSURE_CB_HALF_OPEN_MAX_CALLS=1
UPSURE_DAMAGE_CONCURRENCY=4
UPSURE_OCR_CONCURRENCY=2

# --- Server (gunicorn) ---
UPSURE_WORKERS=1
UPSURE_WORKER_TIMEOUT=180
UPSURE_GRACEFUL_TIMEOUT=30
UPSURE_KEEPALIVE=5
PORT=8000

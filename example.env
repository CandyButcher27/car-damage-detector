# Ollama Cloud API Key — get yours at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Vision model to use on Ollama cloud
OLLAMA_MODEL=

# Ollama cloud base URL (do not change unless Ollama updates it)
OLLAMA_BASE_URL=

# Google Gemini API Key — get free key at https://aistudio.google.com
GEMINI_API_KEY=
